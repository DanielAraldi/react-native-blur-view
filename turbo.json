{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "build:android": {
      "env": ["ORG_GRADLE_PROJECT_newArchEnabled"],
      "inputs": [
        "package.json",
        "android",
        "!android/build",
        "src/*.ts",
        "src/*.tsx",
        "example/cli/package.json",
        "example/cli/android",
        "!example/cli/android/.gradle",
        "!example/cli/android/build",
        "!example/cli/android/app/build",
        "example/tvos/package.json",
        "example/tvos/android",
        "!example/tvos/android/.gradle",
        "!example/tvos/android/build",
        "!example/tvos/android/app/build"
      ],
      "outputs": []
    },
    "build:ios": {
      "env": ["RCT_NEW_ARCH_ENABLED"],
      "inputs": [
        "package.json",
        "*.podspec",
        "ios",
        "src/*.ts",
        "src/*.tsx",
        "example/cli/package.json",
        "example/cli/ios",
        "!example/cli/ios/build",
        "!example/cli/ios/Pods",
        "example/tvos/package.json",
        "example/tvos/ios",
        "!example/tvos/ios/build",
        "!example/tvos/ios/Pods"
      ],
      "outputs": []
    }
  }
}
